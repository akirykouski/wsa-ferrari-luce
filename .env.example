# Copy this file to ".env" and fill in your own credentials. Never commit .env.

# --- Bluesky (AT Protocol) ---
# Create an App Password (NOT your main password):
#   bsky.app -> Settings -> App Passwords
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Reddit Data API (read-only "script" app) ---
# Register an app at https://www.reddit.com/prefs/apps  (type: "script").
# Read-only mode needs ONLY the client id + secret + a descriptive user agent.
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=wsa-ferrari-luce/0.1 by u/yourusername
